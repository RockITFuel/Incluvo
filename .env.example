# --- Database ---
DATABASE_URL=postgres://incluvo:incluvo@localhost:5435/incluvo

# --- Auth (better-auth) ---
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-a-long-random-secret
# Public URL the frontend is served from (used for cookies, CORS, OpenAPI server url)
BETTER_AUTH_URL=http://localhost:3200

# --- Server ---
PORT=3210
NODE_ENV=development
# Comma-separated list of allowed browser origins
CORS_ORIGINS=http://localhost:3200
# Expose the Scalar API docs at /api/docs
ENABLE_API_DOCS=true

# --- Email (dev: Mailpit) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=no-reply@incluvo.local

# --- AI layer (Epic 7) — all optional; unset = deterministic MOCK provider ---
# Any OpenAI-compatible endpoint works (translate / answer-proposals / streaming
# advice + Whisper transcription). For production this MUST be EU-resident
# (Azure OpenAI Data Zone EUR / Mistral EU) — minors' data. Residency is enforced
# at runtime: AI_BASE_URL's host must match AI_ALLOWED_HOSTS (default allow-list:
# *.openai.azure.com, api.mistral.ai), else the provider FAILS CLOSED.
#
# ⚠️ TEMPORARY (current setup): Groq. US-hosted, NOT EU-resident — only acceptable
# while there is NO real minors' data (demo phase). MUST be replaced with an EU
# endpoint before any real data. Groq has no embeddings endpoint, so the
# kennisdocumenten RAG stays on the mock embeddings until then. See memory
# "groq-ai-temporary" and docs/research/ai-layer.md.
# AI_BASE_URL=https://api.groq.com/openai/v1
# AI_API_KEY=                              # your Groq key (gsk_...)
# AI_MODEL=llama-3.3-70b-versatile         # chat: translate + answer-proposals + advies
# AI_TRANSCRIBE_MODEL=whisper-large-v3     # speech-to-text (#18)
# AI_ALLOWED_HOSTS=api.groq.com            # override EU allow-list to permit Groq (TEMPORARY)
#
# Embeddings model for the kennisdocumenten RAG-laag (#20/#22); must output
# 1536 dims to match the DB column (KENNIS_EMBED_DIM). Unset = deterministic mock.
# Groq does NOT serve embeddings — leave unset (mock) or point at an EU embeddings API.
# AI_EMBED_MODEL=text-embedding-3-small

# --- Object storage for course uploads (Epic 4) — optional; unset = local-dev fallback ---
# Use an EU/NL S3-compatible store (e.g. self-hosted MinIO) in production.
# S3_BUCKET=incluvo
# S3_ENDPOINT=https://<minio-host>
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_BASE_URL=

# --- Web (Vite) ---
# Where the web dev server proxies /rpc, /api, /sse to
ORPC_SERVER_URL=http://localhost:3210
